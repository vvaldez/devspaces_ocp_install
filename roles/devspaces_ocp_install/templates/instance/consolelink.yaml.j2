---
apiVersion: console.openshift.io/v1
kind: ConsoleLink
metadata:
  name: devspaces-{{ devspaces_ocp_install_instance['instance_name'] }}
spec:
  applicationMenu:
    imageURL: data:image/svg+xml;base64,
    section: Red Hat Applications
  href: {{ __devspaces_ocp_install_dashboard_url }}
  location: ApplicationMenu
  text: {{ devspaces_ocp_install_instance['link_text'] | default('Dev Spaces (' + devspaces_ocp_install_instance['instance_name'] + ')') }}
